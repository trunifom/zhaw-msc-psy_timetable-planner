if __name__ == "__main__":
    planner = ZHAWPlanner()

    # Exemplarische Master-Module (Psychologie) hinzufügen
    planner.add_module("HS26", "Pflicht", "Forschungsmethoden & Evaluation", 6, "Montag", "09:50 - 12:35")
    planner.add_module("HS26", "Pflicht", "Psychologische Diagnostik", 6, "Dienstag", "13:45 - 16:30")
    planner.add_module("HS26", "Wahlpflicht", "Klinische Psychologie: Intervention", 6, "Mittwoch", "08:00 - 11:45")
    
    # Auswertungen aufrufen
    planner.print_schedule("HS26")
    planner.get_ects_summary()
    planner.export_to_csv()