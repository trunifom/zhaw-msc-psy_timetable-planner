import pandas as pd
import os

class ZHAWPlanner:
    """
    Ein einfacher, strukturierter Stundenplaner für das Masterstudium.
    Verwaltet Module, Zeiten und berechnet den ECTS-Fortschritt.
    """
    
    def __init__(self):
        # Wir definieren ein klares Schema für unsere Daten
        self.columns = ["Semester", "Modultyp", "Modulname", "ECTS", "Wochentag", "Zeit"]
        self.schedule = pd.DataFrame(columns=self.columns)

    def add_module(self, semester: str, modultyp: str, modulname: str, ects: int, wochentag: str, zeit: str):
        """Fügt ein neues Modul zum Stundenplan hinzu."""
        new_module = pd.DataFrame([{
            "Semester": semester,
            "Modultyp": modultyp, # z.B. 'Pflicht', 'Wahlpflicht'
            "Modulname": modulname,
            "ECTS": ects,
            "Wochentag": wochentag,
            "Zeit": zeit
        }])
        # Sicheres Anhängen der neuen Daten
        self.schedule = pd.concat([self.schedule, new_module], ignore_index=True)

    def print_schedule(self, semester: str = None):
        """Gibt den Stundenplan übersichtlich in der Konsole aus."""
        print(f"\n--- 📅 Stundenplan {semester if semester else 'Gesamt'} ---")
        display_df = self.schedule
        if semester:
            display_df = self.schedule[self.schedule["Semester"] == semester]
        
        # Sortieren nach Wochentag für eine logische Ansicht
        days_order = {"Montag": 1, "Dienstag": 2, "Mittwoch": 3, "Donnerstag": 4, "Freitag": 5, "Samstag": 6}
        display_df_sorted = display_df.copy()
        display_df_sorted["Tag_Index"] = display_df_sorted["Wochentag"].map(days_order)
        display_df_sorted = display_df_sorted.sort_values(by=["Tag_Index", "Zeit"]).drop(columns=["Tag_Index"])
        
        print(display_df_sorted.to_markdown(index=False))

    def get_ects_summary(self):
        """Gibt eine Übersicht der erreichten/geplanten ECTS-Punkte pro Semester."""
        print("\n--- 🎓 ECTS Übersicht ---")
        summary = self.schedule.groupby("Semester")["ECTS"].sum().reset_index()
        total_ects = summary["ECTS"].sum()
        print(summary.to_markdown(index=False))
        print(f"**Gesamte ECTS:** {total_ects} / 120 (Standard für Master)")

    def export_to_csv(self, filename: str = "zhaw_master_plan.csv"):
        """Exportiert den Datensatz als CSV-Datei."""
        self.schedule.to_csv(filename, index=False)
        print(f"\n✅ Stundenplan erfolgreich nach '{filename}' exportiert.")

