import pytest
import pandas as pd

# Hinweis: Diese Funktion läge normalerweise in src/data_processing.py
# Für die Demonstration des Test-Konzepts definieren wir sie hier als Dummy.
def anonymize_and_clean(df: pd.DataFrame) -> pd.DataFrame:
    """Entfernt direkte Identifikatoren und füllt fehlende Biomarker-Werte."""
    # 1. DSGVO: Entfernen von PII
    df_clean = df.drop(columns=["name"], errors="ignore")
    # 2. Imputation: Fehlende Werte mit Median auffüllen
    median_val = df_clean["biomarker_level"].median()
    df_clean["biomarker_level"] = df_clean["biomarker_level"].fillna(median_val)
    return df_clean

def test_anonymization_removes_pii(mock_patient_data):
    """Prüft streng, ob datenschutzrelevante Spalten (Namen) entfernt wurden."""
    processed_df = anonymize_and_clean(mock_patient_data)
    
    assert "name" not in processed_df.columns, "KRITISCH: PII-Spalte 'name' wurde nicht entfernt!"
    assert "patient_id" in processed_df.columns, "Pseudonymisierungs-ID darf nicht gelöscht werden!"

def test_imputation_handles_missing_values(mock_patient_data):
    """Prüft, ob fehlende EHR-Datenpunkte (NaNs) statistisch korrekt imputiert werden."""
    # Act
    processed_df = anonymize_and_clean(mock_patient_data)
    
    # Assert
    # Prüfen, ob keine NaN-Werte mehr in der Spalte existieren
    assert not processed_df["biomarker_level"].isna().any(), "Es sind noch fehlende Werte vorhanden!"
    
    # Der Median der Werte [1.2, 3.4, 2.8] ist 2.8.
    # Prüfen, ob der ursprüngliche NaN-Wert bei Index 2 korrekt mit 2.8 gefüllt wurde.
    assert processed_df.loc[2, "biomarker_level"] == 2.8, "Imputation hat nicht den korrekten Median verwendet."
    